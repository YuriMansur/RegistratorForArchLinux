{
  "servers": [
    {
      "name": "PLC1",
      "endpoint": "opc.tcp://192.168.10.10:4840",
      "auto_reconnect": true,
      "reconnect_interval": 5,
      "ns": 2,
      "tags": {
        "rDTAT":        "Application.SensorsHandler.rDTAT",
        "rDavDDA":      "Application.SensorsHandler.rDavDDA",
        "rDavDDB":      "Application.SensorsHandler.rDavDDB",
        "rDavDDN1":     "Application.SensorsHandler.rDavDDN1",
        "rDavDDN2":     "Application.SensorsHandler.rDavDDN2",
        "rDavDDP1":     "Application.SensorsHandler.rDavDDP1",
        "rDavDDP1_1":   "Application.SensorsHandler.rDavDDP1_1",
        "rDavDDP2":     "Application.SensorsHandler.rDavDDP2",
        "rDavReserve1": "Application.SensorsHandler.rDavReserve1",
        "rTempDT1":     "Application.SensorsHandler.rTempDT1",
        "rTempDT2":     "Application.SensorsHandler.rTempDT2",
        "rTempDTB":     "Application.SensorsHandler.rTempDTB",
        "inProcess":    "Application.Control.inProcess",
        "End":          "Application.Control.End"
      },
      "control": {
        "in_process": "inProcess",
        "end":        "End"
      },
      "subscribe": ["inProcess", "End"],
      "polls": [
        {
          "name":       "arrays",
          "interval":   0.5,
          "sequential": false,
          "tags": [
            "rDTAT",
            "rDavDDA",
            "rDavDDB",
            "rDavDDN1",
            "rDavDDN2",
            "rDavDDP1",
            "rDavDDP1_1",
            "rDavDDP2",
            "rDavReserve1",
            "rTempDT1",
            "rTempDT2",
            "rTempDTB",
            "inProcess",
            "End"
          ]
        }
      ]
    }
  ]
}
